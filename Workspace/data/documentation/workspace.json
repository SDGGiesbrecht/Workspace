"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/ProofreadingConfiguration.html","isActive":true,"type":"reference"}]}]},{"content":[{"inlineContent":[{"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/ProofreadingRule\/Cases\/manualWarnings.html","isActive":true,"type":"reference"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/ContinuousIntegrationConfiguration\/Properties\/manage.html"},{"text":" (","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/github.com\/features\/actions"},{"text":")","type":"text"}]}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Generates API ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/APIDocumentationConfiguration\/Properties\/generate.html"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Automates code maintenance:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Tools\/workspace\/Subcommands\/refresh\/Subcommands\/resources.html"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Tools\/workspace\/Subcommands\/refresh\/Subcommands\/inherited%E2%80%90documentation.html","isActive":true,"type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/XcodeConfiguration\/Properties\/manage.html"}]}]}]}]},{"content":[{"inlineContent":[{"text":"Automates open source details:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/FileHeaderConfiguration.html","type":"reference","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/ReadMeConfiguration.html","type":"reference"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/LicenceConfiguration.html"}]}]},{"content":[{"inlineContent":[{"isActive":true,"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Types\/GitHubConfiguration.html","type":"reference"}],"type":"paragraph"}]}],"type":"unorderedList"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Designed to interoperate with the ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/swift.org\/package-manager\/"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Manages projects for macOS, Windows, web, CentOS, Ubuntu, tvOS, iOS, Android, Amazon Linux and watchOS."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Libraries\/WorkspaceConfiguration.html"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":3,"anchor":"The-Workspace-Workflow","text":"The Workspace Workflow","type":"heading"},{"inlineContent":[{"text":"(The following demonstration package is a real repository. You can use it to follow along.)","type":"text"}],"type":"paragraph"},{"level":4,"anchor":"When-the-Repository-Is-Cloned","text":"When the Repository Is Cloned","type":"heading"},{"inlineContent":[{"text":"The need to hunt down workflow tools can deter contributors. On the other hand, including them in the repository causes a lot of clutter. To reduce both, when a project using Workspace is pulled, pushed, or cloned…","type":"text"}],"type":"paragraph"},{"syntax":"shell","code":["git clone https:\/\/github.com\/SDGGiesbrecht\/SDGCornerstone"],"type":"codeListing"},{"inlineContent":[{"text":"…only one small piece of Workspace comes with it: A short script called ","type":"text"},{"code":"Refresh","type":"codeVoice"},{"text":" that has several platform variants.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Hmm… I wish I had more tools at my disposal… Hey! What if I…","type":"text"}],"type":"emphasis"}],"type":"paragraph"},{"level":4,"anchor":"Refresh-the-Project","text":"Refresh the Project","type":"heading"},{"inlineContent":[{"text":"To refresh the project, double‐click the ","type":"text"},{"code":"Refresh","type":"codeVoice"},{"text":" script for your platform. (You can also execute the script from the command line if your system is set up not to execute scripts when they are double‐clicked.)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"code":"Refresh","type":"codeVoice"},{"text":" opens a terminal window, and in it Workspace reports its actions while it sets the project folder up for development. (This may take a while the first time, but subsequent runs are faster.)","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"text":"This looks better. Let’s get coding!","type":"text"}]}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"[Add this… Remove that… Change something over here…]"}]}],"type":"paragraph"},{"inlineContent":[{"type":"emphasis","inlineContent":[{"type":"text","text":"…All done. I wonder if I broke anything while I was working? Hey! It looks like I can…"}]}],"type":"paragraph"},{"level":4,"anchor":"Validate-Changes","text":"Validate Changes","type":"heading"},{"inlineContent":[{"type":"text","text":"When the project seems ready for a push, merge, or pull request, validate the current state of the project by double‐clicking the "},{"type":"codeVoice","code":"Validate"},{"type":"text","text":" script."}],"type":"paragraph"},{"inlineContent":[{"code":"Validate","type":"codeVoice"},{"text":" opens a terminal window and in it Workspace runs the project through a series of checks.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When it finishes, it prints a summary of which tests passed and which tests failed.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Oops! I never realized that would happen…"}],"type":"emphasis"}],"type":"paragraph"},{"level":4,"anchor":"Summary","text":"Summary","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Refresh"},{"type":"text","text":" before working."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Validate","type":"codeVoice"},{"text":" when it looks complete.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Wow! That was so much easier than doing it all manually!"}],"type":"emphasis"}],"type":"paragraph"},{"level":4,"anchor":"Advanced","text":"Advanced","type":"heading"},{"inlineContent":[{"type":"text","text":"While the above workflow is the simplest to learn, Workspace can also be installed as a command line tool that can be used in a wider variety of ways. Most notably, any individual task can be executed in isolation, which can speed things up considerably for users who become familiar with it."}],"type":"paragraph"},{"level":3,"anchor":"Applying-Workspace-to-a-Project","text":"Applying Workspace to a Project","type":"heading"},{"inlineContent":[{"text":"To apply Workspace to a project, run the following command in the root of the project’s repository. (This requires a full install.)","type":"text"}],"type":"paragraph"},{"syntax":"shell","code":["$ workspace refresh"],"type":"codeListing"},{"inlineContent":[{"text":"By default, Workspace refrains from tasks which would involve modifying project files. Such tasks must be activated with a ","type":"text"},{"identifier":"https:\/\/sdggiesbrecht.github.io\/Workspace\/🇬🇧EN\/Libraries\/WorkspaceConfiguration.html","overridingTitleInlineContent":[{"type":"text","text":"configuration"}],"type":"reference","isActive":true,"overridingTitle":"configuration"},{"text":" file. ","type":"text"},{"code":"optIntoAllTasks()","type":"codeVoice"},{"text":" can be used in the configuration file to easily activate everything at once, no matter how much it might end up overwriting.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Workspace\/documentation\/Workspace"},"sections":[],"topicSections":[{"title":"🇬🇧EN","identifiers":["doc:\/\/Workspace\/documentation\/Workspace\/Installation","doc:\/\/Workspace\/documentation\/Workspace\/Importing","doc:\/\/Workspace\/documentation\/Workspace\/Command-Line-Tools","doc:\/\/Workspace\/documentation\/Workspace\/Related-Projects","doc:\/\/Workspace\/documentation\/Workspace\/About"]},{"title":"🇩🇪DE","identifiers":["doc:\/\/Workspace\/documentation\/Workspace\/Installierung","doc:\/\/Workspace\/documentation\/Workspace\/Einfu-hrung","doc:\/\/Workspace\/documentation\/Workspace\/Befehlszeilenprogramme","doc:\/\/Workspace\/documentation\/Workspace\/Verwandte-Projekte"]},{"title":"Products","identifiers":["doc:\/\/Workspace\/documentation\/Workspace\/Library-Products"]},{"title":"Articles","identifiers":["doc:\/\/Workspace\/documentation\/Workspace\/workspace-normalize-help","doc:\/\/Workspace\/documentation\/Workspace\/workspace-normalize","doc:\/\/Workspace\/documentation\/Workspace\/workspace-refresh-license-help","doc:\/\/Workspace\/documentation\/Workspace\/workspace-refresh-license"],"generated":true}],"metadata":{"roleHeading":"Framework","externalID":"Workspace","symbolKind":"module","title":"Workspace","modules":[{"name":"Workspace"}],"role":"collection"},"kind":"symbol","hierarchy":{"paths":[[]]},"abstract":[{"text":"Wor