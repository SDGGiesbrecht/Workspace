er","kind":"identifier"}],"url":"\/documentation\/workspaceconfiguration\/localisationidentifier","kind":"symbol","navigatorTitle":[{"text":"LocalisationIdentifier","kind":"identifier"}],"role":"symbol","type":"topic","identifier":"doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration\/LocalisationIdentifier","abstract":[{"text":"A localisation identifier; either an IETF language tag or a language icon.","type":"text"}]}}}