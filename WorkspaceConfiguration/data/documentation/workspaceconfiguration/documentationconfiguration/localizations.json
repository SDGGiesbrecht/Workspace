ceConfiguration":{"title":"WorkspaceConfiguration","kind":"symbol","url":"\/documentation\/workspaceconfiguration","abstract":[{"text":"The root API used in configuration files.","type":"text"}],"role":"collection","type":"topic","identifier":"doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration"}}}