{"metadata":{"externalID":"s:22WorkspaceConfiguration16ProofreadingRuleO7unicodeyA2CmF","modules":[{"name":"WorkspaceConfiguration"}],"title":"ProofreadingRule.unicode","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"unicode"}],"role":"symbol","symbolKind":"case","roleHeading":"Case"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/workspaceconfiguration\/proofreadingrule\/unicode"]}],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration","doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration\/ProofreadingRule"]]},"primaryContentSections":[{"kind":"declarations","declarations":[{"platforms":["Linux"],"languages":["swift"],"tokens":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"unicode","kind":"identifier"}]}]},{"kind":"content","content":[{"level":2,"text":"Discussion","anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"This rule still permits most uses where the proper characters would not work:"}],"type":"paragraph"},{"code":["print(\"Hello, world!\") \/\/ ← Allowed, because quotation marks cannot be used instead."],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"In some contexts, such as when creating aliases, marked exemptions may be necessary:"}],"type":"paragraph"},{"code":["func ≠ (a: Any, b: Any) -> Bool {","   return a != b \/\/ @exempt(from: unicode)","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"This rule covers:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Horizontal strokes:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Hyphens: “twenty‐one” (U+2010) instead of “twenty-one” (U+002D)."}]}]},{"content":[{"inlineContent":[{"text":"Minus signs: “3 − 1 = 2” (U+2212) instead of “3 - 1 = 2” (U+002D).","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Dashes: “—” instead of “--”.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Bullets: “•” instead of “-”."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Range symbols: “Dec. 3–5” (U+2013) instead of “Dec. 3-5” (U+002D).","type":"text"}]}]}]}]},{"content":[{"inlineContent":[{"text":"Raised marks:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Quotation marks: “… ‘…’ …” (U+2018–U+201F) instead of \"… '…' …\" (U+0022, U+0027).","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Apostrophes: “it’s” (U+2019) instead of “it's” (U+0027)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Degrees symbols: “20°C” instead of “20'C”.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Prime symbols: 5′6′′ (U+2032) instead of 5'6\" (U+0027, U+0022)."}]}]}],"type":"unorderedList"}]},{"content":[{"inlineContent":[{"text":"“×” instead of “*”.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"“÷” instead of “\/”.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"“≠” instead of “!=”."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"“≤” instead of “<=”.","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"“≥” instead of “>=”."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"“¬” instead of “!”."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"“∧” instead of “&&”."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"“∨” instead of “||”.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}]}],"sections":[],"abst