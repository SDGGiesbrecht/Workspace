{"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","hierarchy":{"paths":[["doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration","doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration\/ProofreadingRule"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/workspaceconfiguration\/proofreadingrule\/workaroundreminders"]}],"metadata":{"externalID":"s:22WorkspaceConfiguration16ProofreadingRuleO19workaroundRemindersyA2CmF","modules":[{"name":"WorkspaceConfiguration"}],"title":"ProofreadingRule.workaroundReminders","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"workaroundReminders"}],"roleHeading":"Case","role":"symbol","symbolKind":"case"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration\/ProofreadingRule\/workaroundReminders"},"sections":[],"primaryContentSections":[{"declarations":[{"languages":["swift"],"platforms":["Linux"],"tokens":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"workaroundReminders"}]}],"kind":"declarations"},{"content":[{"text":"Discussion","level":2,"anchor":"discussion","type":"heading"},{"inlineContent":[{"type":"text","text":"Workaround reminders are for times when you need to implement a temporary workaround because of a problem in a dependency, and you would like to remind yourself to go back and remove the workaround once the dependency is fixed."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The text, "},{"type":"codeVoice","code":"#workaround(Some description here.)"},{"type":"text","text":" will trigger a warning during proofreading, but will still pass validation."}],"type":"paragraph"},{"text":"Version Detection","level":3,"anchor":"Version-Detection","type":"heading"},{"inlineContent":[{"type":"text","text":"Optionally, a workaround reminder can specify the dependency and version were the problem exists. Then Workspace will ignore it until the problematic version is out of date."}],"type":"paragraph"},{"inlineContent":[{"type":"codeVoice","code":"#workaround(SomeDependency 0.0.0, Some description here.)"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The dependency can be specified three different ways."}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"text":"Package dependencies can be specified using the exact name of the package.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ #workaround(MyLibrary 1.0.0, There is a problem in MyLibrary.)"]}]},{"content":[{"inlineContent":[{"text":"Swift itself can be specified with the string ","type":"text"},{"code":"Swift","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"code":["\/\/ #workaround(Swift 3.0.2, There is a problem with Swift.)"],"syntax":"swift","type":"codeListing"}]},{"content":[{"inlineContent":[{"type":"text","text":"Arbitrary dependencies can be specified by shell commands which output a version number. Workspace will look for the first group of the characters "},{"type":"codeVoice","code":"0"},{"type":"text","text":"–"},{"type":"codeVoice","code":"9"},{"type":"text","text":" and "},{"type":"codeVoice","code":"."},{"type":"text","text":" in the command output. Only simple commands are supported; commands cannot contain quotation marks."}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ #workaround(git --version 2.10.1, There is a problem with Git.) @exempt(from: unicode)"],"syntax":"swift"}]}],"type":"unorderedList"}],"kind":"content"}],"abstract":[{"type":"text","text":"Catches outdated workaround reminders."}],"references":{"doc://WorkspaceConfiguration/documentation/WorkspaceConfiguration/ProofreadingRule/workaroundReminders":{"fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"text":"workaroundReminders","kind":"identifier"}],"kind":"symbol","title":"ProofreadingRule.workaroundReminders","type":"topic","identifier":"doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration\/ProofreadingRule\/workaroundReminders","url":"\/documentation\/workspaceconfiguration\/proofreadingrule\/workaroundreminders","role":"symbol","abstract":[{"type":"text","text":"Catches outdated workaround reminders."}]},"doc://WorkspaceConfiguration/documentation/WorkspaceConfiguration/ProofreadingRule":{"fragments":[{"text":"enum","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ProofreadingRule","kind":"identifier"}],"kind":"symbol","title":"ProofreadingRule","type":"topic","navigatorTitle":[{"text":"ProofreadingRule","kind":"identifier"}],"identifier":"doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration\/ProofreadingRule","url":"\/documentation\/workspaceconfiguration\/proofreadingrule","role":"symbol","abstract":[{"type":"text","text":"A proofreading rule."}]},"doc://WorkspaceConfiguration/documentation/WorkspaceConfiguration":{"title":"WorkspaceConfiguration","kind":"symbol","url":"\/documentation\/workspaceconfiguration","abstract":[{"text":"The root API used in configuration files.","type":"text"}],"role":"collection","type":"topic","identifier":"doc:\/\/WorkspaceConfiguration\/documentation\/WorkspaceConfiguration"}}}